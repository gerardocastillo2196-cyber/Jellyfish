# Jellyfish OS - ejemplo de configuracion

JELLYFISH_PROVIDER="ollama"
JELLYFISH_MODEL="qwen2.5-agent:latest"
JELLYFISH_CONTEXT_LIMIT="8192"

# Ollama local
OLLAMA_URL="http://localhost:11434/api/chat"

# Proveedores cloud OpenAI-compatible
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"

DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"

OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

GEMINI_API_KEY="AIzaSyAu60FORYOqZyHfHya6lnpu8iM2K5UhOYw"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"

DASHSCOPE_API_KEY=""
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

KIMI_API_KEY=""
KIMI_BASE_URL="https://api.moonshot.ai/v1"

ZHIPU_API_KEY=""
ZHIPU_BASE_URL="https://open.bigmodel.cn/api/paas/v4"

# Para cualquier API compatible con OpenAI Chat Completions
CUSTOM_API_KEY=""
CUSTOM_BASE_URL=""

# Subagentes opcionales
JELLYFISH_SUBAGENT_PROVIDER=""
JELLYFISH_SUBAGENT_MODEL=""

# RAG
JELLYFISH_RAG_THRESHOLD="1.2"
JELLYFISH_EMBED_MODEL="nomic-embed-text"

# Proyecto activo opcional
JELLYFISH_ACTIVE_PROJECT=""
JELLYFISH_PROJECT_METHODOLOGY="scrum"
