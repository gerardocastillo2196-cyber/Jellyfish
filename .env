# ╔══════════════════════════════════════════════════╗
# ║        JELLYFISH OS — Configuración .env         ║
# ╚══════════════════════════════════════════════════╝

# --- Proveedor de IA ---
# Opciones: "ollama" | "openai" | "deepseek" | "openrouter"
JELLYFISH_PROVIDER="ollama"

# --- Modelo ---
# Para ollama: qwen2.5-agent:latest, llama3, codellama, etc.
# Para openai: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# Para deepseek: deepseek-chat, deepseek-coder, deepseek-reasoner
# Para openrouter: meta-llama/llama-3-70b-instruct, etc.
JELLYFISH_MODEL="qwen2.5-agent:latest"

# --- API Keys (solo para proveedores en la nube) ---
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""
OPENROUTER_API_KEY=""

# --- URLs personalizadas (opcional, tienen valores por defecto) ---
# OLLAMA_URL="http://localhost:11434/api/chat"
# OPENAI_BASE_URL="https://api.openai.com/v1"
# DEEPSEEK_BASE_URL="https://api.deepseek.com"
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# --- RAG ---
# Umbral de relevancia L2 (menor = más estricto). Default: 1.2
# JELLYFISH_RAG_THRESHOLD="1.2"

# --- Modelo de Embeddings para RAG ---
# JELLYFISH_EMBED_MODEL="nomic-embed-text"
